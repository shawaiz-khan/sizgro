<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"> <!-- Screen views ko visually map kiya gaya hai is XML line ke rules se -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"> <!-- XML attribute ya element ko configure karke user interface mein design parameters set kiye ja rahe hain -->

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Product Details"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="32dp" /> <!-- App resources ko layout rendering system me utilize karne ka structure is attribute me maujood hai -->

        <EditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Product Name"
            android:padding="16dp"
            android:background="@drawable/edittext_bg"
            android:layout_marginBottom="16dp" /> <!-- Ye layout tag application UI ka ek visual component define kar raha hai -->

        <EditText
            android:id="@+id/etPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Price ($)"
            android:inputType="numberDecimal"
            android:padding="16dp"
            android:background="@drawable/edittext_bg"
            android:layout_marginBottom="16dp" /> <!-- Screen views ko visually map kiya gaya hai is XML line ke rules se -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Category"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="4dp" /> <!-- XML attribute ya element ko configure karke user interface mein design parameters set kiye ja rahe hain -->

        <Spinner
            android:id="@+id/spinnerCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:background="@drawable/edittext_bg"
            android:layout_marginBottom="16dp" /> <!-- User interface hierarchy ka ek part yahan par build aur screen pe link kiya ja raha hai -->

        <EditText
            android:id="@+id/etDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Description"
            android:inputType="textMultiLine"
            android:minLines="4"
            android:gravity="top"
            android:padding="16dp"
            android:background="@drawable/edittext_bg"
            android:layout_marginBottom="32dp" /> <!-- Ye layout tag application UI ka ek visual component define kar raha hai -->

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Product"
            android:backgroundTint="@color/accent"
            android:padding="16dp" /> <!-- Ye tag application ki screen ka koi element ya container represent karta hai -->

        <Button
            android:id="@+id/btnDelete"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Delete Product"
            android:backgroundTint="#FF5252"
            android:layout_marginTop="8dp"
            android:visibility="gone" /> <!-- User interface hierarchy ka ek part yahan par build aur screen pe link kiya ja raha hai -->

    </LinearLayout> <!-- Ye tag application ki screen ka koi element ya container represent karta hai -->
</ScrollView> <!-- Ye layout tag application UI ka ek visual component define kar raha hai -->
