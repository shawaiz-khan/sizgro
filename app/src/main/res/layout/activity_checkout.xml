<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"> <!-- App resources ko layout rendering system me utilize karne ka structure is attribute me maujood hai -->

    <LinearLayout
        android:id="@+id/checkoutHeader"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/white"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:elevation="4dp"> <!-- Ye layout tag application UI ka ek visual component define kar raha hai -->

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textSize="24sp"
            android:textColor="@color/accent"
            android:padding="4dp" /> <!-- XML attribute ya element ko configure karke user interface mein design parameters set kiye ja rahe hain -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Checkout"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:gravity="center"
            android:layout_marginEnd="32dp" /> <!-- Ye tag application ki screen ka koi element ya container represent karta hai -->
    </LinearLayout> <!-- Screen views ko visually map kiya gaya hai is XML line ke rules se -->

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/checkoutHeader"
        android:layout_above="@id/confirmBar"> <!-- App resources ko layout rendering system me utilize karne ka structure is attribute me maujood hai -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"> <!-- Screen views ko visually map kiya gaya hai is XML line ke rules se -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Delivery Address"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:layout_marginBottom="8dp" /> <!-- Screen views ko visually map kiya gaya hai is XML line ke rules se -->

            <EditText
                android:id="@+id/etAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="House No., Street name, City"
                android:background="@drawable/edittext_bg"
                android:padding="16dp"
                android:layout_marginBottom="24dp" /> <!-- User interface hierarchy ka ek part yahan par build aur screen pe link kiya ja raha hai -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Payment Method"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:layout_marginBottom="8dp" /> <!-- User interface hierarchy ka ek part yahan par build aur screen pe link kiya ja raha hai -->

            <Spinner
                android:id="@+id/spinnerPayment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/edittext_bg"
                android:padding="16dp"
                android:layout_marginBottom="32dp" /> <!-- App resources ko layout rendering system me utilize karne ka structure is attribute me maujood hai -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="20dp"> <!-- Ye layout tag application UI ka ek visual component define kar raha hai -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Order Summary"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:layout_marginBottom="12dp" /> <!-- User interface hierarchy ka ek part yahan par build aur screen pe link kiya ja raha hai -->

                <TextView
                    android:id="@+id/tvCheckoutItems"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Items: Loading..."
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp" /> <!-- Ye tag application ki screen ka koi element ya container represent karta hai -->

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"> <!-- User interface hierarchy ka ek part yahan par build aur screen pe link kiya ja raha hai -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Items Total"
                        android:textColor="@color/text_secondary" /> <!-- XML attribute ya element ko configure karke user interface mein design parameters set kiye ja rahe hain -->
                    <TextView
                        android:id="@+id/tvSummarySubtotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="$0.00"
                        android:textColor="@color/black" /> <!-- App resources ko layout rendering system me utilize karne ka structure is attribute me maujood hai -->
                </RelativeLayout> <!-- App resources ko layout rendering system me utilize karne ka structure is attribute me maujood hai -->

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"> <!-- User interface hierarchy ka ek part yahan par build aur screen pe link kiya ja raha hai -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Shipment Cost"
                        android:textColor="@color/text_secondary" /> <!-- App ki presentation layer (UI module) ka view element configuration complete kar raha hai -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="$2.00"
                        android:textColor="@color/black" /> <!-- App resources ko layout rendering system me utilize karne ka structure is attribute me maujood hai -->
                </RelativeLayout> <!-- Ye layout tag application UI ka ek visual component define kar raha hai -->

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#DDDDDD"
                    android:layout_marginBottom="16dp" /> <!-- App ki presentation layer (UI module) ka view element configuration complete kar raha hai -->

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"> <!-- XML attribute ya element ko configure karke user interface mein design parameters set kiye ja rahe hain -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Payable"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:textSize="18sp" /> <!-- User interface hierarchy ka ek part yahan par build aur screen pe link kiya ja raha hai -->
                    <TextView
                        android:id="@+id/tvSummaryTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="$2.00"
                        android:textStyle="bold"
                        android:textColor="@color/accent"
                        android:textSize="18sp" /> <!-- App ki presentation layer (UI module) ka view element configuration complete kar raha hai -->
                </RelativeLayout> <!-- Ye layout tag application UI ka ek visual component define kar raha hai -->
            </LinearLayout> <!-- XML attribute ya element ko configure karke user interface mein design parameters set kiye ja rahe hain -->

        </LinearLayout> <!-- App resources ko layout rendering system me utilize karne ka structure is attribute me maujood hai -->
    </ScrollView> <!-- Ye tag application ki screen ka koi element ya container represent karta hai -->

    <LinearLayout
        android:id="@+id/confirmBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:padding="16dp"
        android:background="@color/white"
        android:elevation="8dp"> <!-- Screen views ko visually map kiya gaya hai is XML line ke rules se -->

        <Button
            android:id="@+id/btnPlaceOrder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Place Order"
            android:backgroundTint="@color/accent"
            android:padding="16dp"
            android:textAllCaps="false"
            android:textStyle="bold" /> <!-- App ki presentation layer (UI module) ka view element configuration complete kar raha hai -->

    </LinearLayout> <!-- Screen views ko visually map kiya gaya hai is XML line ke rules se -->

</RelativeLayout> <!-- App resources ko layout rendering system me utilize karne ka structure is attribute me maujood hai -->
