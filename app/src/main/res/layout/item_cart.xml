<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/card_bg"
    android:layout_marginBottom="12dp"
    android:padding="12dp"
    android:gravity="center_vertical"> <!-- App ki presentation layer (UI module) ka view element configuration complete kar raha hai -->

    <ImageView
        android:id="@+id/ivCartProduct"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@drawable/logo_color"
        android:scaleType="centerInside" /> <!-- App resources ko layout rendering system me utilize karne ka structure is attribute me maujood hai -->

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="16dp"> <!-- User interface hierarchy ka ek part yahan par build aur screen pe link kiya ja raha hai -->

        <TextView
            android:id="@+id/tvCartProductName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Product Name"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/black" /> <!-- App ki presentation layer (UI module) ka view element configuration complete kar raha hai -->

        <TextView
            android:id="@+id/tvCartProductCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Category"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" /> <!-- Ye tag application ki screen ka koi element ya container represent karta hai -->

        <TextView
            android:id="@+id/tvCartProductQty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Qty: 1"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:layout_marginTop="2dp" /> <!-- XML attribute ya element ko configure karke user interface mein design parameters set kiye ja rahe hain -->
    </LinearLayout> <!-- App resources ko layout rendering system me utilize karne ka structure is attribute me maujood hai -->

    <TextView
        android:id="@+id/tvCartProductPrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="$0.00"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/accent" /> <!-- User interface hierarchy ka ek part yahan par build aur screen pe link kiya ja raha hai -->

</LinearLayout> <!-- Ye layout tag application UI ka ek visual component define kar raha hai -->
