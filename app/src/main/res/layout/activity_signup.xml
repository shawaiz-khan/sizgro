<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal"
    android:background="@color/white"> <!-- XML attribute ya element ko configure karke user interface mein design parameters set kiye ja rahe hain -->

    <ImageView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/logo_color"
        android:layout_marginTop="48dp"
        android:layout_marginBottom="32dp" /> <!-- XML attribute ya element ko configure karke user interface mein design parameters set kiye ja rahe hain -->

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Create Account"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:layout_marginBottom="8dp" /> <!-- Screen views ko visually map kiya gaya hai is XML line ke rules se -->

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Join SizGro grocery community"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="32dp" /> <!-- User interface hierarchy ka ek part yahan par build aur screen pe link kiya ja raha hai -->

    <EditText
        android:id="@+id/etEmail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Email"
        android:inputType="textEmailAddress"
        android:padding="16dp"
        android:background="@drawable/edittext_bg"
        android:layout_marginBottom="16dp" /> <!-- User interface hierarchy ka ek part yahan par build aur screen pe link kiya ja raha hai -->

    <EditText
        android:id="@+id/etPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Password"
        android:inputType="textPassword"
        android:padding="16dp"
        android:background="@drawable/edittext_bg"
        android:layout_marginBottom="16dp" /> <!-- User interface hierarchy ka ek part yahan par build aur screen pe link kiya ja raha hai -->

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Select Role"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="4dp" /> <!-- User interface hierarchy ka ek part yahan par build aur screen pe link kiya ja raha hai -->

    <Spinner
        android:id="@+id/spinnerRole"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:background="@drawable/edittext_bg"
        android:layout_marginBottom="24dp" /> <!-- Screen views ko visually map kiya gaya hai is XML line ke rules se -->

    <Button
        android:id="@+id/btnSignup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sign Up"
        android:backgroundTint="@color/accent"
        android:textColor="@color/white"
        android:padding="16dp"
        android:textAllCaps="false" /> <!-- Screen views ko visually map kiya gaya hai is XML line ke rules se -->

    <TextView
        android:id="@+id/tvLogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Already have an account? Login"
        android:textColor="@color/accent"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        android:padding="8dp" /> <!-- Screen views ko visually map kiya gaya hai is XML line ke rules se -->

</LinearLayout> <!-- Ye layout tag application UI ka ek visual component define kar raha hai -->
