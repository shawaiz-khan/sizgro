<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"> <!-- User interface hierarchy ka ek part yahan par build aur screen pe link kiya ja raha hai -->

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/white"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"> <!-- App resources ko layout rendering system me utilize karne ka structure is attribute me maujood hai -->

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Seller Panel"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/black" /> <!-- Screen views ko visually map kiya gaya hai is XML line ke rules se -->

        <ImageView
            android:id="@+id/btnLogout"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_lock_power_off"
            android:contentDescription="Logout" /> <!-- Ye tag application ki screen ka koi element ya container represent karta hai -->
    </LinearLayout> <!-- Screen views ko visually map kiya gaya hai is XML line ke rules se -->

    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header"
        android:text="Your inventory is empty.\nStart by adding your first product!"
        android:gravity="center"
        android:padding="32dp"
        android:textSize="18sp"
        android:textColor="@color/text_secondary"
        android:visibility="gone" /> <!-- Ye layout tag application UI ka ek visual component define kar raha hai -->

    <ListView
        android:id="@+id/listViewInventory"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header"
        android:padding="8dp"
        android:divider="@android:color/transparent"
        android:dividerHeight="8dp" /> <!-- Ye layout tag application UI ka ek visual component define kar raha hai -->

    <Button
        android:id="@+id/btnAddProduct"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="24dp"
        android:text="Add New Product"
        android:backgroundTint="@color/accent"
        android:textColor="@color/white"
        android:textAllCaps="false"
        android:paddingLeft="24dp"
        android:paddingRight="24dp" /> <!-- App resources ko layout rendering system me utilize karne ka structure is attribute me maujood hai -->

</RelativeLayout> <!-- User interface hierarchy ka ek part yahan par build aur screen pe link kiya ja raha hai -->
