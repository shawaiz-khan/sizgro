<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface"> <!-- Screen views ko visually map kiya gaya hai is XML line ke rules se -->

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/white"
        android:padding="16dp"> <!-- Ye layout tag application UI ka ek visual component define kar raha hai -->

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/logo_color"
            android:layout_centerVertical="true" /> <!-- App resources ko layout rendering system me utilize karne ka structure is attribute me maujood hai -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SizGro"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/accent"
            android:layout_centerInParent="true" /> <!-- XML attribute ya element ko configure karke user interface mein design parameters set kiye ja rahe hain -->

        <TextView
            android:id="@+id/btnCart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🛒"
            android:textSize="24sp"
            android:padding="4dp"
            android:layout_toStartOf="@id/btnLogout"
            android:layout_marginEnd="12dp"
            android:layout_centerVertical="true"
            android:contentDescription="Cart" /> <!-- App resources ko layout rendering system me utilize karne ka structure is attribute me maujood hai -->

        <ImageView
            android:id="@+id/btnLogout"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_lock_power_off"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:contentDescription="Logout" /> <!-- Ye tag application ki screen ka koi element ya container represent karta hai -->
    </RelativeLayout> <!-- User interface hierarchy ka ek part yahan par build aur screen pe link kiya ja raha hai -->

    <EditText
        android:id="@+id/etSearch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Search for products..."
        android:drawableStart="@android:drawable/ic_menu_search"
        android:drawablePadding="12dp"
        android:padding="12dp"
        android:layout_margin="12dp"
        android:background="@drawable/edittext_bg"
        android:textSize="14sp" /> <!-- Screen views ko visually map kiya gaya hai is XML line ke rules se -->

    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:text="No products found"
        android:gravity="center"
        android:textSize="18sp"
        android:textColor="@color/text_secondary"
        android:visibility="gone" /> <!-- XML attribute ya element ko configure karke user interface mein design parameters set kiye ja rahe hain -->

    <GridView
        android:id="@+id/gridViewProducts"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:numColumns="2"
        android:padding="8dp"
        android:verticalSpacing="8dp"
        android:horizontalSpacing="8dp"
        android:stretchMode="columnWidth" /> <!-- User interface hierarchy ka ek part yahan par build aur screen pe link kiya ja raha hai -->

</LinearLayout> <!-- Ye tag application ki screen ka koi element ya container represent karta hai -->
