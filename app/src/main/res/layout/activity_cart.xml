<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"> <!-- App resources ko layout rendering system me utilize karne ka structure is attribute me maujood hai -->

    <LinearLayout
        android:id="@+id/cartHeader"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/white"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:elevation="4dp"> <!-- Ye layout tag application UI ka ek visual component define kar raha hai -->

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textSize="24sp"
            android:textColor="@color/accent"
            android:padding="4dp" /> <!-- Ye layout tag application UI ka ek visual component define kar raha hai -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Your Shopping Cart"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:gravity="center"
            android:layout_marginEnd="32dp" /> <!-- XML attribute ya element ko configure karke user interface mein design parameters set kiye ja rahe hain -->
    </LinearLayout> <!-- User interface hierarchy ka ek part yahan par build aur screen pe link kiya ja raha hai -->

    <LinearLayout
        android:id="@+id/llEmptyCart"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/cartHeader"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone"> <!-- App ki presentation layer (UI module) ka view element configuration complete kar raha hai -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🛒"
            android:textSize="64sp"
            android:layout_marginBottom="16dp" /> <!-- App resources ko layout rendering system me utilize karne ka structure is attribute me maujood hai -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your cart is empty"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/black" /> <!-- App resources ko layout rendering system me utilize karne ka structure is attribute me maujood hai -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Looks like you haven't added anything yet."
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginTop="8dp" /> <!-- App ki presentation layer (UI module) ka view element configuration complete kar raha hai -->

        <Button
            android:id="@+id/btnContinueShopping"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Continue Shopping"
            android:backgroundTint="@color/accent"
            android:layout_marginTop="24dp"
            android:textAllCaps="false" /> <!-- App ki presentation layer (UI module) ka view element configuration complete kar raha hai -->
    </LinearLayout> <!-- Ye layout tag application UI ka ek visual component define kar raha hai -->

    <LinearLayout
        android:id="@+id/llCartContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/cartHeader"
        android:layout_above="@id/bottomBar"
        android:orientation="vertical"
        android:padding="16dp"> <!-- Ye layout tag application UI ka ek visual component define kar raha hai -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Items in cart"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="16dp" /> <!-- App ki presentation layer (UI module) ka view element configuration complete kar raha hai -->

        <!-- We'll use a single item view for mock, or a ListView if you want multiple -->
        <ListView
            android:id="@+id/listViewCart"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:divider="@android:color/transparent"
            android:dividerHeight="0dp" /> <!-- App ki presentation layer (UI module) ka view element configuration complete kar raha hai -->

    </LinearLayout> <!-- User interface hierarchy ka ek part yahan par build aur screen pe link kiya ja raha hai -->

    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@color/white"
        android:elevation="8dp"> <!-- XML attribute ya element ko configure karke user interface mein design parameters set kiye ja rahe hain -->

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"> <!-- Ye layout tag application UI ka ek visual component define kar raha hai -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Estimated Total"
                android:textSize="16sp"
                android:textColor="@color/text_secondary" /> <!-- Ye tag application ki screen ka koi element ya container represent karta hai -->
            <TextView
                android:id="@+id/tvCartTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="$0.00"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/accent" /> <!-- Ye layout tag application UI ka ek visual component define kar raha hai -->
        </RelativeLayout> <!-- App resources ko layout rendering system me utilize karne ka structure is attribute me maujood hai -->

        <Button
            android:id="@+id/btnGoToCheckout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Go to Checkout"
            android:backgroundTint="@color/accent"
            android:padding="16dp"
            android:textAllCaps="false" /> <!-- Screen views ko visually map kiya gaya hai is XML line ke rules se -->

    </LinearLayout> <!-- App resources ko layout rendering system me utilize karne ka structure is attribute me maujood hai -->

</RelativeLayout> <!-- App ki presentation layer (UI module) ka view element configuration complete kar raha hai -->
