<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/card_bg"
    android:padding="12dp"
    android:gravity="center_horizontal"> <!-- Ye tag application ki screen ka koi element ya container represent karta hai -->

    <ImageView
        android:id="@+id/ivProduct"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@drawable/logo_color"
        android:scaleType="centerInside" /> <!-- Screen views ko visually map kiya gaya hai is XML line ke rules se -->

    <TextView
        android:id="@+id/tvProductName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Product Name"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="8dp" /> <!-- Screen views ko visually map kiya gaya hai is XML line ke rules se -->

    <TextView
        android:id="@+id/tvProductPrice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="$10.00"
        android:textColor="@color/accent"
        android:textSize="14sp"
        android:textStyle="bold" /> <!-- XML attribute ya element ko configure karke user interface mein design parameters set kiye ja rahe hain -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp"
        android:gravity="center_vertical"> <!-- Screen views ko visually map kiya gaya hai is XML line ke rules se -->

        <TextView
            android:id="@+id/btnBuyNow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="BUY"
            android:textColor="@color/accent"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="8dp"
            android:background="?attr/selectableItemBackground" /> <!-- Ye layout tag application UI ka ek visual component define kar raha hai -->

        <TextView
            android:id="@+id/btnAddToCart"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:text="ADD"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="8dp"
            android:background="@drawable/edittext_bg"
            android:backgroundTint="@color/accent" /> <!-- Ye layout tag application UI ka ek visual component define kar raha hai -->
    </LinearLayout> <!-- App resources ko layout rendering system me utilize karne ka structure is attribute me maujood hai -->

</LinearLayout> <!-- XML attribute ya element ko configure karke user interface mein design parameters set kiye ja rahe hain -->
